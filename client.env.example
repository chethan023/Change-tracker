# ── Client Identity (set per-deployment — never hardcode a real client name) ──
CLIENT_NAME=Change Tracker
CLIENT_LOGO_URL=
CLIENT_PRIMARY_COLOUR=#1B3A6B

# ── Security ───────────────────────────────────────
INGEST_API_KEY=local-test-key-123
JWT_SECRET_KEY=local-jwt-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Database ───────────────────────────────────────
DB_PASSWORD=localpassword
DATABASE_URL=postgresql+psycopg2://ct_user:localpassword@db:5432/changetracker

# ── Redis / Celery ─────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── STEP ───────────────────────────────────────────
STEP_BASE_URL=https://step.example.com

# ── Email Notifications (optional) ─────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=PIM Change Tracker <noreply@example.com>

# ── Slack Notifications (optional) ─────────────────
SLACK_DEFAULT_WEBHOOK_URL=

# ── App Config ─────────────────────────────────────
MAX_USERS=10
LOG_LEVEL=INFO

# ── Bootstrap Seed Users (required — created on first DB startup) ─
# Admin: full access · Editor: write · Viewer: read-only
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_EDITOR_EMAIL=
BOOTSTRAP_EDITOR_PASSWORD=
BOOTSTRAP_VIEWER_EMAIL=
BOOTSTRAP_VIEWER_PASSWORD=
