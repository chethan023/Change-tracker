            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="ListOfValue" type="ListOfValueType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="LocalBusinessRuleType">
        <xs:annotation>
            <xs:documentation>
