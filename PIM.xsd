                <xs:annotation>
                    <xs:documentation>
                        The configuration in encoded form.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="ID" type="StepProcessID" use="required"/>
    </xs:complexType>

</xs:schema>