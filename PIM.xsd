                <xs:element name="Asset" type="AssetType" minOccurs="0">
                    <xs:annotation>
                        <xs:documentation>
                            Embedded reference target. Has no effect during import.
                        </xs:documentation>
                    </xs:annotation>
                </xs:element>
            </xs:choice>
        </xs:sequence>
        <xs:attribute name="Type" type="StepLinkTypeID" use="required">
            <xs:annotation>
                <xs:documentation>
                    ID of the reference type.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="AssetID" type="StepAssetID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    ID of the referenced asset. Required if a KeyValue is not supplied.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="AnalyzerResult" type="xs:string" use="optional">
            <xs:annotation>
                <xs:documentation>
                    @Deprecated, to be removed in a future release.

                    WebPublisher specific attribute. Identifies whether the referenced asset is present on the website.
                    Possible values: included, excluded
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Changed" use="optional" default="false" type="xs:boolean">
        </xs:attribute>
        <xs:attribute name="QualifierID" type="StepQualifierID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Identifies in which contexts this reference is visible. If not specified, the current context is
                    used.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Inherited" type="xs:integer" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Only relevant during export when nested inside a partial hierarchy. If present during import,
                    the link is simply ignored. If this attribute is present then link is inherited. Will not
                    be exported for local links (thus only numbers 1 and upward will be exported - 1 indicating
                    inherited from immediate parent).
                    The integer value of this attribute indicates how far up this link is inherited from.
                    In cross context exports it might be relevant to have this number to find the most relevant link
                    for a given context.
                    NOTE: will only inherit inside hierarchy of equal node types - ie. will not inherit from
                    classification to product hierarchy.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="AssetCrossReferenceTypeType">
        <xs:annotation>
            <xs:documentation>
                The definition of a reference type for which references point to assets.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="MetaData" type="MetaDataType" minOccurs="0"/>
            <xs:element name="AttributeLink" type="AttributeLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="DimensionLink" type="DimensionLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="AttributeGroupLink" type="AttributeGroupLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="UserTypeLink" type="UserTypeLinkType" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>
                        Link to a valid source type. Notice that this source can be a DataContainerType.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TargetUserTypeLink" type="TargetUserTypeLinkType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
        <xs:attribute name="Inherited" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether or not references of this type are hierarchically inherited. Cannot be "false" if
                    the value for the Accumulated attribute is "true".
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ID" type="StepLinkTypeID" use="required"/>
        <xs:attribute name="Revised" use="optional" default="true" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether references of this type are under revision control or not (externally maintained).
                    During import, for existing reference types for which references exist, the value can be changed
                    from "false" to "true" if the import runs in single update mode but cannot be changed from "true"
                    to "false".
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Completeness" type="xs:string" use="optional">
            <xs:annotation>
                <xs:documentation>
                    @Deprecated, not used anymore after the introduction of Completeness Metrics in STEP 7.4 (see
                    documentation on Completeness Metrics and migration from old pre-7.4 completeness functionality).
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="MultiValued" use="optional" default="true" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Whether the type allows for multiple references from the same source or not. Can for existing
                    reference types be changed from "false" to "true". Changing from "true" to "false" requires that no
                    present source has multiple references.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Mandatory" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether or not this reference type is mandatory for approval.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Accumulated" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether or not reference inheritance should be accumulated. Can only be "true" if
                    the value for the MultiValued attribute is "true".
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
    </xs:complexType>
    <xs:complexType name="AssetElementType">
        <xs:choice minOccurs="0">
            <xs:element name="RuleBasedLayout" type="RuleBasedLayoutType"/>
            <xs:element name="KeyValue" type="KeyValueType"/>
            <xs:element name="TemplateLayout" type="TemplateLayoutType"/>
            <xs:element name="PickupLayout" type="PickupLayoutType"/>
        </xs:choice>
        <xs:attribute name="ExtendToFrameID" type="StepID" use="optional"/>
        <xs:attribute name="FrameID" type="StepID" use="optional"/>
