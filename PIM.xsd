        </xs:attribute>
        <xs:attribute name="DerivedContextID" type="StepQualifierID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Identifies the calculation context for derived / calculated attribute values.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ID" type="LOVValueID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Value ID for LOV based attributes for which the LOV uses value IDs.
                </xs:documentation>
            </xs:annotation>
