        </xs:sequence>
        <xs:attribute name="RejectNewAssets" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Instruction that can be used during import to prevent the creation of new assets.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="DefaultParentID" type="StepClassificationID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Import instruction. The default parent classification for new assets that do not have an explicit
                    classification reference.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="DefaultUserTypeID" type="StepObjectTypeID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Import instruction. The default object type for new assets for which no object type is supplied.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
