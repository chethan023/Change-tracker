<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="http://www.stibosystems.com/step"
           xmlns="http://www.stibosystems.com/step"
           elementFormDefault="qualified" attributeFormDefault="unqualified">
    <xs:element name="STEP-ProductInformation">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="ReplacementRules" type="ReplacementRulesType" minOccurs="0"/>
                <xs:element name="TagGroupList" type="TagGroupListType" minOccurs="0"/>
                <xs:element name="TagList" type="TagListType" minOccurs="0"/>
                <xs:element name="DimensionList" type="DimensionListType" minOccurs="0"/>
                <xs:element name="Qualifiers" type="QualifiersType" minOccurs="0"/>
                <xs:element name="ContextList" type="ContextListType" minOccurs="0"/>
                <xs:element name="CrossContexts" type="CrossContextsType" minOccurs="0"/>
                <xs:element name="GlobalSettings" type="GlobalSettingsType" minOccurs="0"/>
                <xs:element name="UserTypes" type="UserTypesType" minOccurs="0"/>
                <xs:element name="Keys" type="KeysType" minOccurs="0"/>
                <xs:element name="EdgeTypes" type="EdgeTypesType" minOccurs="0"/>
                <xs:element name="DerivedEventTypes" type="DerivedEventTypesType" minOccurs="0"/>
                <xs:element name="CrossReferenceTypes" type="CrossReferenceTypesType" minOccurs="0"/>
                <xs:element name="DeleteAssets" type="DeleteAssetsType" minOccurs="0"/>
                <xs:element name="DeleteProducts" type="DeleteProductsType" minOccurs="0"/>
                <xs:element name="DeleteEntities" type="DeleteEntitiesType" minOccurs="0"/>
                <xs:element name="DeleteClassifications" type="DeleteClassificationsType" minOccurs="0"/>
                <xs:element name="UnitList" type="UnitListType" minOccurs="0"/>
                <xs:element name="CollectionList" type="CollectionListType" minOccurs="0"/>
                <xs:element name="ListOfValuesGroupList" type="ListOfValuesGroupListType" minOccurs="0"/>
                <xs:element name="ListsOfValues" type="ListsOfValuesType" minOccurs="0"/>
                <xs:element name="AttributeGroupList" type="AttributeGroupListType" minOccurs="0"/>
                <xs:element name="AttributeList" type="AttributeListType" minOccurs="0"/>
                <xs:element name="AttributeTransformationGroups" type="AttributeTransformationGroupsType"
                            minOccurs="0"/>
                <xs:element name="TableColors" type="TableColorsType" minOccurs="0"/>
                <xs:element name="TableRules" type="TableRulesType" minOccurs="0"/>
                <xs:element name="TableTypeGroupList" type="RowColumnTableGroupListType" minOccurs="0"/>
                <xs:element name="ColumnTypeGroupList" type="RowColumnTableGroupListType" minOccurs="0"/>
                <xs:element name="RowTypeGroupList" type="RowColumnTableGroupListType" minOccurs="0"/>
                <xs:element name="TableTypes" type="TableTypesType" minOccurs="0"/>
                <xs:element name="ColumnTypes" type="ColumnTypesType" minOccurs="0"/>
                <xs:element name="RowTypes" type="RowTypesType" minOccurs="0"/>
                <xs:element name="DataContainerTypes" type="DataContainerTypesType" minOccurs="0"/>
                <xs:element name="SetupGroups" type="SetupGroupsType" minOccurs="0"/>
                <xs:element name="SetupEntities" type="SetupEntitiesType" minOccurs="0"/>
                <xs:element name="BusinessLibraries" type="BusinessLibrariesType" minOccurs="0"/>
                <xs:element name="BusinessRules" type="BusinessRulesType" minOccurs="0"/>
                <xs:element name="STEPWorkflows" type="STEPWorkflowsType" minOccurs="0"/>
                <xs:element name="StatusFlags" type="StatusFlagsType" minOccurs="0"/>
                <xs:element name="STEPWorkflowProfiles" type="STEPWorkflowProfilesType" minOccurs="0"/>
                <xs:element name="MatchCodes" type="MatchCodesType" minOccurs="0"/>
                <xs:element name="MatchingAlgorithms" type="MatchingAlgorithmsType" minOccurs="0"/>
                <xs:element name="Classifications" type="ClassificationsType" minOccurs="0"/>
                <xs:element name="PublicationGroups" type="PublicationGroupsType" minOccurs="0"/>
                <xs:element name="Assets" type="AssetsType" minOccurs="0"/>
                <xs:element name="Entities" type="EntitiesType" minOccurs="0"/>
                <xs:element name="Products" type="ProductsType" minOccurs="0"/>
                <xs:element name="ActionSetList" type="ActionSetListType" minOccurs="0"/>
                <xs:element name="UserGroupList" type="UserGroupListType" minOccurs="0"/>
                <xs:element name="UserList" type="UserListType" minOccurs="0"/>
                <xs:element name="SystemSetup" type="SystemSetupType" minOccurs="0"/>
                <xs:element name="ImportConfigurations" type="ImportConfigurationsType" minOccurs="0"/>
                <xs:element name="ExportConfigurations" type="ExportConfigurationsType" minOccurs="0"/>
                <xs:element name="TranslationConfigurations" type="TranslationConfigurationsType" minOccurs="0"/>
                <xs:element name="BulkUpdateConfigurations" type="BulkUpdateConfigurationsType" minOccurs="0"/>
                <xs:element name="TransformationLookupTableConfigurations" type="TransformationLookupTableConfigurationsType" minOccurs="0"/>
                <xs:element name="ImageConversionConfigurations" type="ImageConversionConfigurationsType" minOccurs="0"/>
                <xs:element name="AssetPushEventQueues" type="AssetPushEventQueuesType" minOccurs="0"/>
                <xs:element name="AssetPushConfigurations" type="AssetPushConfigurationsType" minOccurs="0"/>
                <xs:element name="ECatalogs" type="ECatalogsType" minOccurs="0"/>
                <xs:element name="PortalConfigurations" type="PortalConfigurationsType" minOccurs="0"/>
                <xs:element name="DeleteUnits" type="DeleteUnitsType" minOccurs="0"/>
                <xs:element name="DeleteAttributes" type="DeleteAttributesType" minOccurs="0"/>
                <xs:element name="DeleteListOfValues" type="DeleteListOfValuesType" minOccurs="0"/>
                <xs:element name="EventQueues" type="EventQueuesType" minOccurs="0"/>
                <xs:element name="MissingObjects" type="MissingObjectsType" minOccurs="0"/>
                <xs:element name="IntegrationEndpoints" type="IntegrationEndpointsType" minOccurs="0"/>
                <xs:element name="EventProcessors" type="EventProcessorsType" minOccurs="0"/>
                <xs:element name="ChangePackages" type="ChangePackagesType" minOccurs="0"/>
                <xs:element name="ComponentModels" type="ComponentModelsType" minOccurs="0"/>
                <xs:element name="ScheduledProcesses" type="ScheduledProcessesType" minOccurs="0"/>
            </xs:sequence>
            <xs:attribute name="ContextID" type="StepQualifierID" use="optional">
                <xs:annotation>
                    <xs:documentation>
                        Specifies the ID of the context that provides the content selection for an export.
                        During import, it identifies the context to which data without an explicit QualifierID
                        specification will be associated.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="AutoApprove" type="YesNoType" use="optional" default="N"/>
            <xs:attribute name="AutoInitiate" type="YesNoType" use="optional" default="N"/>
            <xs:attribute name="StateflowImportEvent" type="YesNoType" use="optional" default="N">
                <xs:annotation>
                    <xs:documentation>
                        @Deprecated, replaced by STEPWorkflowImportEvent.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="STEPWorkflowImportEvent" type="YesNoType" use="optional" default="N"/>
            <xs:attribute name="ExportTransactionID" type="StepID" use="optional" default="-1">
                <xs:annotation>
                    <xs:documentation>
                        @Deprecated, may be removed in a future release.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ReplaceProductValues" type="YesNoType" use="optional" default="N">
                <xs:annotation>
                    <xs:documentation>
                        @Deprecated, use ReplacementRules/Products/ReplaceValues instead.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="AllowInvalidValues" type="YesNoType" use="optional" default="N">
                <xs:annotation>
                    <xs:documentation>
                        Reserved for future use. Does currently not have any effect.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ReplaceAttributeLinks" type="YesNoType" use="optional" default="N">
                <xs:annotation>
                    <xs:documentation>
                        @Deprecated, use ReplacementRules/Products/ReplaceAttributeLinks or
                        ReplacementRules/Classifications/ReplaceAttributeLinks instead.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ReplaceProductToProductCrossReferences" type="YesNoType" use="optional" default="N">
                <xs:annotation>
                    <xs:documentation>
                        @Deprecated, use ReplacementRules/Products/ReplaceCrossReferences instead.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ExportContext" type="StepQualifierID" use="optional">
                <xs:annotation>
                    <xs:documentation>
                        ID of the context in which the export was performed. Ignored on import.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ReplaceTerms" use="optional" default="CLEAR_ONLY_FOR_IMPORTED_PRODUCTS">
                <xs:simpleType>
                    <xs:restriction base="xs:NMTOKEN">
                        <xs:enumeration value="CLEAR_ENTIRE_TERMSLISTS"/>
                        <xs:enumeration value="CLEAR_ONLY_FOR_IMPORTED_PRODUCTS"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:attribute>
            <xs:attribute name="ReplaceClassificationToClassificationCrossReferences" type="YesNoType"
                          use="optional" default="N">
                <xs:annotation>
                    <xs:documentation>
                        @Deprecated, use ReplacementRules/Classifications/ReplaceCrossReferences instead.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ReplaceOverrideToSubProductReferences" use="optional" default="N" type="YesNoType">
                <xs:annotation>
                    <xs:documentation>
                        Either "Y" or "N". Specifies whether or not imported OverrideSubProduct should replace
                        existing sub products of product overrides.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="SingleUpdateMode" type="YesNoType" use="optional" default="N">
                <xs:annotation>
                    <xs:documentation>
                        Either "Y" or "N". Specifies whether or not the whole import will run in single update mode.
                        Specifying "Y" is required for certain import operations, e.g. adding dimension dependencies
                        and changing validation. When specifying "N", operations requiring single update mode to execute
                        will be skipped and warnings will be issued.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="WorkspaceID" type="StepID" use="optional">
                <xs:annotation>
                    <xs:documentation>
                        Specifies the ID of the workspace that provides the content selection for an export. During
                        import, it identifies the workspace to which data will be associated.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ReplaceProductToClassificationReferences" type="YesNoType" use="optional" default="N">
                <xs:annotation>
                    <xs:documentation>
                        @Deprecated, use ReplacementRules/Products/ReplaceClassificationReferences instead.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ReplaceClassificationValues" type="YesNoType" use="optional" default="N">
                <xs:annotation>
                    <xs:documentation>
                        @Deprecated, use ReplacementRules/Classifications/ReplaceValues instead.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ReplaceEntityValues" type="YesNoType" use="optional" default="N">
                <xs:annotation>
                    <xs:documentation>
                        @Deprecated, use ReplacementRules/Entities/ReplaceValues instead.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ReplaceValidUserTypesForAttributes" type="YesNoType" use="optional" default="N">
                <xs:annotation>
                    <xs:documentation>
                        @Deprecated, use ReplacementRules/Attributes/ReplaceUserTypeLinks instead.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ExportTime" type="xs:string" use="optional">
                <xs:annotation>
                    <xs:documentation>
                        Specifies the starting time for an export in the format "YYYY-MM-DD HH:MM:SS", eg "1999-10-15
                        12:00:00".
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="UseContextLocale" type="xs:boolean" use="optional" default="false">
                <xs:annotation>
                    <xs:documentation>
                        Used for export only. Specifies whether or not data has been converted according to the context
                        locale.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ApproveTranslationTarget" type="StepID" use="optional">
                <xs:annotation>
                    <xs:documentation>
                        ID of the language dimension point for which translations should be approved.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="SuppressReTranslations" type="YesNoType" use="optional" default="N"/>
            <xs:attribute name="AutoFillQualifiers" type="YesNoType" use="optional" default="N"/>
            <xs:attribute name="ExportValidAndAbsent" type="xs:boolean" use="optional" default="false">
                <xs:annotation>
                    <xs:documentation>
                        Export includes absent data as "blank" values/terms/names or cross-references/links without target.
                        If imported back into STEP, that data will be deleted (pending the required privileges).
                        (Import is not implemented yet, as of STEP 11)
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="ApproximateMemoryRequirement" type="xs:long" use="optional"/>
        </xs:complexType>
    </xs:element>
    <xs:simpleType name="ConfigurationType">
        <xs:annotation>
            <xs:documentation>
                A configuration is not human readable, as it has been zipped and encoded in BASE64. The content of the
                configuration is a contract between the exporter and the importer, and must not be altered in between.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:base64Binary"/>
    </xs:simpleType>
    <xs:simpleType name="EntityRevisabilityType">
        <xs:restriction base="xs:NMTOKEN">
            <xs:enumeration value="Global"/>
            <xs:enumeration value="Workspace"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="GUISetupAdvancedType">
        <xs:annotation>
            <xs:documentation>
                Puts the GUI menu item in the advanced sub menu.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string"/>
    </xs:simpleType>
    <xs:simpleType name="GUISetupDisabledType">
        <xs:annotation>
            <xs:documentation>
                Disables a menu item.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string"/>
    </xs:simpleType>
    <xs:simpleType name="GUISetupEnabledType">
        <xs:annotation>
            <xs:documentation>
                Enables a menu item.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string"/>
    </xs:simpleType>
    <xs:simpleType name="GUITopType">
        <xs:annotation>
            <xs:documentation>
                A step URL, restricting the user to a top tree node in the Tree editor.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string"/>
    </xs:simpleType>
    <xs:simpleType name="NonEmptyStringType">
        <xs:restriction base="xs:string">
            <xs:pattern value=".+"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="ParentChildRelationType">
        <xs:restriction base="xs:NMTOKEN">
            <xs:enumeration value="NONE"/>
            <xs:enumeration value="TARGETASCHILD"/>
            <xs:enumeration value="SOURCEASCHILD"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="ReferenceTargetLockPolicyType">
        <xs:restriction base="xs:NMTOKEN">
            <xs:enumeration value="Strict"/>
            <xs:enumeration value="Relaxed"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="RuleBasedLayoutType">
        <xs:restriction base="xs:string"/>
    </xs:simpleType>
    <xs:simpleType name="StepID">
        <xs:restriction base="xs:string">
            <xs:maxLength value="40"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="LOVValueID">
        <xs:restriction base="xs:string">
            <xs:maxLength value="100"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="StepActionID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepActionSetID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepAssetPushConfigurationID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepAssetPushEventQueueID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepAttributeID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepBusinessRuleID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepDataContainerTypeID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepEventProcessorID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepEventQueueID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepGatewayEndPointID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepImageConversionConfigurationID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepInboundEndPointID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepKeyID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepLinkTypeID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepLOVID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepMatchCodeID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepMatchingAlgorithmID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepObjectTypeID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepOutboundEndPointID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepPortalConfigurationID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepQualifierID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepReferenceTypeID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepSetupEntityID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepSetupGroupID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepTermsListID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepTradingTermsID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepUnitID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepUserGroupID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepUserID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepWorkflowID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepWorkflowProfileID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepProductID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepClassificationID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepEntityID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepAssetID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepNodeCollectionID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepProcessID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="StepTagGroupID"><xs:restriction base="StepID"/></xs:simpleType>
    <xs:simpleType name="TagID">
        <xs:restriction base="xs:string">
            <xs:maxLength value="2000"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="TwoDecimalValueType">
        <xs:restriction base="xs:decimal">
            <xs:fractionDigits fixed="true" value="2" />
        </xs:restriction>
    </xs:simpleType>
    <xs:simpleType name="YesNoType">
        <xs:restriction base="xs:NMTOKEN">
            <xs:enumeration value="Y"/>
            <xs:enumeration value="N"/>
        </xs:restriction>
    </xs:simpleType>
    <xs:complexType name="ActionLinkType">
        <xs:annotation>
            <xs:documentation>
                A link to an action.
            </xs:documentation>
        </xs:annotation>
        <xs:attribute name="ActionID" type="StepActionID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the action.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="ActionSetType">
        <xs:annotation>
            <xs:documentation>
                A set of actions that can be granted to a user through privilege rules.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="MetaData" type="MetaDataType" minOccurs="0"/>
            <xs:element name="ActionLink" type="ActionLinkType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
        <xs:attribute name="ID" type="StepActionSetID" use="required"/>
        <xs:attribute name="Type" use="required">
            <xs:annotation>
                <xs:documentation>
                    Determines whether the action set is a setup or a user action set.
                    Has one of the values 'setup' or 'user' accordingly.
                </xs:documentation>
            </xs:annotation>
            <xs:simpleType>
                <xs:restriction base="xs:NMTOKEN">
                    <xs:enumeration value="setup"/>
                    <xs:enumeration value="user"/>
                </xs:restriction>
            </xs:simpleType>
        </xs:attribute>
        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
    </xs:complexType>
    <xs:complexType name="ActionSetListType">
        <xs:annotation>
            <xs:documentation>
                A list of action sets.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="ActionSet" type="ActionSetType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="AssetType">
        <xs:annotation>
            <xs:documentation>
                Describes an asset in STEP. The Asset element lists its names, references and values. Note that assets
                don't have their own hierarchy. Therefore they must, for creation, be nested inside a classification
                element and/or have a ClassificationReference sub element. DTP Document assets may contain pages that
                have been created by a DTP client.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="KeyValue" type="KeyValueType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="AssetPushLocation" type="AssetPushLocationType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:sequence>
                <xs:element name="DeleteSuppressedClassificationReference"
                            type="DeleteSuppressedClassificationReferenceType" minOccurs="0" maxOccurs="unbounded"/>
                <xs:element name="DeleteClassificationReference" type="DeleteClassificationReferenceType" minOccurs="0"
                            maxOccurs="unbounded"/>
                <xs:element name="SuppressedClassificationReference" type="SuppressedClassificationReferenceType"
                            minOccurs="0" maxOccurs="unbounded"/>
                <xs:element name="ClassificationReference" type="ClassificationReferenceType" minOccurs="0"
                            maxOccurs="unbounded"/>
            </xs:sequence>
            <xs:sequence>
                <xs:element name="DeleteSuppressedEntityCrossReference" type="DeleteSuppressedEntityCrossReferenceType"
                            minOccurs="0" maxOccurs="unbounded"/>
                <xs:element name="DeleteEntityCrossReference" type="DeleteEntityCrossReferenceType" minOccurs="0"
                            maxOccurs="unbounded"/>
                <xs:element name="SuppressedEntityCrossReference" type="SuppressedEntityCrossReferenceType"
                            minOccurs="0" maxOccurs="unbounded"/>
                <xs:element name="EntityCrossReference" type="EntityCrossReferenceType" minOccurs="0"
                            maxOccurs="unbounded"/>
            </xs:sequence>
            <xs:element name="Values" type="ValuesType" minOccurs="0"/>
            <xs:element name="CurrentTasks" type="CurrentTasksType" minOccurs="0"/>
            <xs:element name="Pages" type="PagesType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="AssetContent" type="AssetContentType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="AssetBinaryContent" type="AssetBinaryContentType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
        <xs:attribute name="Changed" use="optional" default="false" type="xs:boolean"/>
        <xs:attribute name="SourcePos" type="xs:string" use="optional"/>
        <xs:attribute name="ID" type="StepAssetID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    ID of the asset. Not required for creation if auto IDs are configured for the asset object type. Not
                    required for updates if a KeyValue is supplied.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Republished" use="optional" default="false" type="xs:boolean">
        </xs:attribute>
        <xs:attribute name="UserTypeID" type="StepObjectTypeID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Identifies the object type of the object. Required when new assets are created if DefaultUserTypeID
                    is not set.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="AnalyzerResult" type="xs:string" use="optional">
            <xs:annotation>
                <xs:documentation>
