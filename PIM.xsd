                <xs:documentation>
                    Qualifier information for values for LOV based attributes for which the LOV is dimension dependent.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="AttributeID" type="StepAttributeID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    The ID of the attribute of this value. Can be omitted if value is part of a MultiValue element.
                </xs:documentation>
