                    <xs:enumeration value="CCR"/>
                    <xs:enumeration value="P"/>
                    <xs:enumeration value="PPR"/>
                    <xs:enumeration value="PCR"/>
                    <xs:enumeration value="PA"/>
                    <xs:enumeration value="ACR"/>
