    <xs:complexType name="EntityCrossReferenceTypeType">
        <xs:annotation>
            <xs:documentation>
                The definition of a reference type for which references point to entities.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="MetaData" type="MetaDataType" minOccurs="0"/>
            <xs:element name="AttributeLink" type="AttributeLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="DimensionLink" type="DimensionLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="AttributeGroupLink" type="AttributeGroupLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="UserTypeLink" type="UserTypeLinkType" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>
                        Link to a valid source type. Notice that this source can be a DataContainerType.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TargetUserTypeLink" type="TargetUserTypeLinkType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
        <xs:attribute name="Inherited" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether or not references of this type are hierarchically inherited. Cannot be "false" if
                    the value for the Accumulated attribute is "true".
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ID" type="StepLinkTypeID" use="required"/>
        <xs:attribute name="Revised" use="optional" default="true" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether references of this type are under revision control or not (externally maintained).
                    During import, for existing reference types for which references exist, the value can be changed
                    from "false" to "true" if the import runs in single update mode but cannot be changed from "true"
                    to "false".
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Completeness" type="xs:string" use="optional">
            <xs:annotation>
                <xs:documentation>
                    @Deprecated, not used anymore after the introduction of Completeness Metrics in STEP 7.4 (see
                    documentation on Completeness Metrics and migration from old pre-7.4 completeness functionality).
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="MultiValued" use="optional" default="true" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Whether the type allows for multiple references from the same source or not. Can for existing
                    reference types be changed from "false" to "true". Changing from "true" to "false" requires that no
                    present source has multiple references.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Mandatory" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether or not this reference type is mandatory for approval.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ParentChildRelation" use="optional" type="ParentChildRelationType"/>
        <xs:attribute name="Accumulated" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether or not reference inheritance should be accumulated. Can only be "true" if
                    the value for the MultiValued attribute is "true".
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="InheritPrivilegesFromTargetToSource" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether or not the privilege system should use reference to let source inherit privileges from target.
                    Can only be "true" if "ParentChildRelation" is "SOURCEASCHILD" and there are no "DimensionLink".
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
