                <xs:element name="Entity" type="EntityType" minOccurs="0">
                    <xs:annotation>
                        <xs:documentation>
                            Embedded reference target. Has no effect during import.
                        </xs:documentation>
                    </xs:annotation>
                </xs:element>
            </xs:choice>
        </xs:sequence>
        <xs:attribute name="Type" type="StepLinkTypeID" use="required">
            <xs:annotation>
                <xs:documentation>
                    ID of the reference type.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="EntityID" type="StepEntityID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    ID of the referenced entity. Required if a KeyValue is not supplied.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="AnalyzerResult" type="xs:string" use="optional">
            <xs:annotation>
                <xs:documentation>
                    @Deprecated, to be removed in a future release.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Changed" use="optional" default="false" type="xs:boolean"/>
        <xs:attribute name="QualifierID" type="StepQualifierID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Identifies which contexts this reference is visible in. If not specified the current context is used.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Inherited" type="xs:integer" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Only relevant during export when nested inside a partial hierarchy. If present during import,
                    the link is simply ignored. If this attribute is present then link is inherited. Will not
                    be exported for local links (thus only numbers 1 and upward will be exported - 1 indicating
                    inherited from immediate parent).
                    The integer value of this attribute indicates how far up this link is inherited from.
                    In cross context exports it might be relevant to have this number to find the most relevant link
                    for a given context.
                    NOTE: will only inherit inside hierarchy of equal node types - ie. will not inherit from
                    classification to product hierarchy.
