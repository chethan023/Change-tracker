                    The parent publication of this version. Only required if version not available in current context.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="VisibleTermFieldsType">
        <xs:sequence>
            <xs:element name="VisibleTermField" type="VisibleTermFieldType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
