            <xs:element name="Dependency" type="BusinessRuleDependencyType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="Configuration" type="ConfigurationType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="ValidObjectTypes" type="ValidObjectTypesType" minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
        <xs:attribute name="ID" type="StepBusinessRuleID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the business rule.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Scope" use="required">
            <xs:annotation>
                <xs:documentation>
                    The scope of the business rule. Always "Local".
                </xs:documentation>
            </xs:annotation>
            <xs:simpleType>
                <xs:restriction base="xs:NMTOKEN">
                    <xs:enumeration value="Local"/>
                    <xs:enumeration value="Global"/>
                </xs:restriction>
            </xs:simpleType>
        </xs:attribute>
        <xs:attribute name="Type" use="optional">
            <xs:annotation>
                <xs:documentation>
                    The type of the business rule.
                </xs:documentation>
            </xs:annotation>
            <xs:simpleType>
                <xs:restriction base="xs:NMTOKEN">
                    <xs:enumeration value="Condition"/>
                    <xs:enumeration value="Action"/>
                </xs:restriction>
            </xs:simpleType>
        </xs:attribute>
        <xs:attribute name="RunPrivileged" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Run privileged - without privilege check. Ignored for business rules of type Library.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
