                    systems are (however customizations can be made): text, number, integer,
                    numeric_text, embedded_number, fraction, novalidation, boolean, date,
                    isodate and isodatetime.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="MaxValue" type="xs:string" use="optional">
            <xs:annotation>
                <xs:documentation>
                    The maximum value allowed for numerically validated attributes.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="ValidObjectTypeType">
        <xs:annotation>
