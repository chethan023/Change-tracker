        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
    </xs:complexType>
    <xs:complexType name="ListOfValuesGroupListType">
        <xs:annotation>
            <xs:documentation>
                Container element fro LOV groups.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="ListOfValuesGroup" type="ListOfValuesGroupType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="ListOfValueType">
        <xs:annotation>
            <xs:documentation>
                Represents an LOV. Values in the LOV have the dimension dependencies described by the dimension links
                and must conform to the validation rules described in Validation. The list of values is described by the
                nested Value and/or ValueGroup elements.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="Validation" type="ValidationType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>
                        Validation specification. During import, for existing LOVs, the validation can be modified if
                        the import is running in single update mode and no conflicting values exist.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="DimensionLink" type="DimensionLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="MetaData" type="MetaDataType" minOccurs="0"/>
            <xs:element name="AttributeGroupLink" type="AttributeGroupLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:choice>
                <xs:element name="Value" type="ValueType" minOccurs="0" maxOccurs="unbounded"/>
                <xs:element name="ValueGroup" type="ValueGroupType" minOccurs="0" maxOccurs="unbounded"/>
            </xs:choice>
            <xs:element name="DeleteValue" type="DeleteValueType" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>
                        Allows for the deletion of a specific value in the LOV.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="ID" type="StepLOVID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    ID of the LOV object. Not required for creation if auto IDs are configured for the object type.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ParentID" type="StepLOVID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    ID of the parent LOV group. If not supplied during creation, LOV will be created at the top level.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="AllowUserValueAddition" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Whether or not users are allowed to add values to the LOV while maintaining attribute values.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="UseValueID" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Whether value IDs are used for values in this LOV. Can only be "true" if the value for
                    "AllowUserValueAddition" is "false".
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="IDPattern" type="xs:string" use="optional">
            <xs:annotation>
                <xs:documentation>
                    The pattern used for auto generated value IDs.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ReplaceListOfValuesValues" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Determines whether the contained list of values should replace all the existing contents of this
                    LOV, or whether a value-element should add missing values and delete-value-elements remove existing
                    values incrementally. When replacing, missing values in this LOV will only be deleted if they have
                    no present usage (and events will/need not be generated).
                    Relevant only for import; this is not a feature of the LOV that will be persisted or exported.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="DefaultUnitID" type="StepUnitID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    The ID of the default unit for values of this LOV.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
    </xs:complexType>
    <xs:complexType name="ListOfValueLinkType">
        <xs:annotation>
            <xs:documentation>
                Represents a link to an LOV.
            </xs:documentation>
        </xs:annotation>
        <xs:attribute name="ListOfValueID" type="StepLOVID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the LOV.
                </xs:documentation>
            </xs:annotation>
