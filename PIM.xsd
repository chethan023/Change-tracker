    <xs:complexType name="AttributeOriginType">
        <xs:attribute name="ID" type="xs:string" use="optional"/>
        <xs:attribute name="AttributeID" type="StepAttributeID" use="optional"/>
        <xs:attribute name="Pull" type="xs:string" use="optional"/>
    </xs:complexType>
    <xs:complexType name="AttributeType">
        <xs:annotation>
            <xs:documentation>
                This element represents an attribute in the system. The validation or ListOfValueLink restricts the
                valid values of this attribute. The dimension links is the dimension dependencies for values of this
                attribute. UserTypeLink and LinkType list the objects that are allowed to have values of this attribute.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:choice>
                <xs:element name="Validation" type="ValidationType" minOccurs="0">
                    <xs:annotation>
                        <xs:documentation>
                            Validation specification for non-LOV based attributes. During import, for existing
                            attributes with values, the validation can be modified if the import is running in single
                            update mode and no conflicting present values exist. Existing attributes can be changed to
                            be LOV validated if the import is running in single update mode, the revisability settings
                            (externally maintained or not) of attribute and LOV match and if the existing data fits the
                            LOV validation. In this case existing values will be added to the LOV.
                        </xs:documentation>
                    </xs:annotation>
                </xs:element>
                <xs:element name="ListOfValueLink" type="ListOfValueLinkType">
                    <xs:annotation>
                        <xs:documentation>
                            List of values link for LOV-validated attributes. Existing attributes can be changed to not
                            be LOV validated if the import is running in single update mode and the existing values
                            match the defined (target) validation.
                        </xs:documentation>
                    </xs:annotation>
                </xs:element>
            </xs:choice>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="ValueTemplate" type="ValueTemplateType"/>
                <xs:element name="UnitTemplate" type="UnitTemplateType"/>
            </xs:choice>
            <xs:element name="DimensionLink" type="DimensionLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="MetaData" type="MetaDataType" minOccurs="0"/>
            <xs:element name="AttributeGroupLink" type="AttributeGroupLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="UserTypeLink" type="UserTypeLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="LinkType" type="LinkTypeType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="ValueFilter" type="ValueFilterType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>
                        LOV value filter.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="CurrentTasks" type="CurrentTasksType" minOccurs="0"/>
        </xs:sequence>
        <xs:attribute name="HierarchicalFiltering" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Whether or not it is allowed to have LOV value filters on product to attribute links. Notice that if
                    the value is changed from "true" to "false" for an existing attribute, exiting LOV filters on
                    product to attribute links will be removed.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ClassificationHierarchicalFiltering" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Whether or not it is allowed to have LOV value filters on classification to attribute links. Notice
                    that if the value is changed from "true" to "false" for an existing attribute, exiting LOV filters
                    on classification to attribute links will be removed.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ExternallyMaintained" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Whether or not values of this attribute are externally maintained. If not externally maintained,
                    full revision control of values of this attribute is available. During import, for existing
                    attributes with values, the value can be changed from "true" to "false" if the import runs in single
                    update mode but cannot be changed from "false" to "true".
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="FullTextIndexed" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Whether or not values of this attribute should be full text indexed. Can for existing attributes
                    be changed during import if the import is running in single update mode.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="MultiValued" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Whether attribute is multi valued or not. Can for existing attributes be changed from "false" to
                    "true". Changing from "true" to "false" requires that no present or past multivalued values exist.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ID" type="StepAttributeID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    The ID of the attribute object. Not required for creation if auto IDs are configured for attributes.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="DefaultUnitID" type="StepUnitID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    The ID of the default unit for values of this attribute.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ProductMode" use="optional" default="Normal">
            <xs:annotation>
                <xs:documentation>
                    Whether this attribute is a specification attribute ("Normal") or a description attribute
                    ("Property").
                </xs:documentation>
            </xs:annotation>
            <xs:simpleType>
                <xs:restriction base="xs:NMTOKEN">
                    <xs:enumeration value="Normal"/>
                    <xs:enumeration value="Property"/>
                </xs:restriction>
            </xs:simpleType>
        </xs:attribute>
        <xs:attribute name="Mandatory" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether or not this attribute is mandatory for approval.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Derived" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether or not this attribute is derived (calculated). Can for existing attributes, during
                    import, be changed from "false" to "true" but not the other way.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Referenced" use="optional" default="false" type="xs:boolean"/>
        <xs:attribute name="CryptographicKeyID" use="optional" type="StepID">
            <xs:annotation>
                <xs:documentation>
                    The ID of the cryptographic key if the attribute is encrypted. Cannot be changed if the attribute
                    has values.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Completeness" type="xs:string" use="optional">
            <xs:annotation>
                <xs:documentation>
                    @Deprecated, not used anymore after the introduction of Completeness Metrics in STEP 7.4 (see
                    documentation on Completeness Metrics and migration from old pre-7.4 completeness functionality).
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Deleted" use="optional" default="false" type="xs:boolean"/>
    </xs:complexType>
    <xs:complexType name="ReferenceTypeType">
        <xs:annotation>
            <xs:documentation>
                This element represents a reference type in the system.
            </xs:documentation>
        </xs:annotation>
        <xs:attribute name="ID" type="StepLinkTypeID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the reference type object. Not required for creation if auto IDs are configured for reference types.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="AttributeTypeType">
        <xs:annotation>
            <xs:documentation>
                This element represents a attribute in the system.
            </xs:documentation>
        </xs:annotation>
        <xs:attribute name="ID" type="StepAttributeID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the attribute object. Not required for creation if auto IDs are configured for attributes.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="AttributeSequenceType">
        <xs:annotation>
            <xs:documentation>
                The sequence of attributes in a manually sorted attribute group. On import, any attributes not mentioned
                in the sequence will be left in the beginning of the sequence.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="AttributeLink" type="AttributeLinkType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="AttributeGroupType">
        <xs:annotation>
            <xs:documentation>
                An attribute group holding a number of attributes or attribute groups.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="MetaData" type="MetaDataType" minOccurs="0"/>
            <xs:element name="Configuration" type="ConfigurationType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>
                        View definition in encoded form.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="AttributeSequence" type="AttributeSequenceType" minOccurs="0"/>
            <xs:element name="AttributeGroup" type="AttributeGroupType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
        <xs:attribute name="ID" type="StepAttributeID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    ID of the attribute group object. Not required for creation if auto IDs are configured for attribute
                    groups.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ParentID" type="StepAttributeID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    ID of the parent attribute group.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ShowInWorkbench" type="xs:boolean" use="optional" default="true">
            <xs:annotation>
                <xs:documentation>
                    True if this attribute group should be shown in the workbench when editing
                    references and values. Defaults to true if not set (for example on upgraded databases).
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ExcludeFromProfiling" type="xs:boolean" use="optional">
            <xs:annotation>
                <xs:documentation>
                    @Deprecated, not used anymore after the introduction of attribute group filtering in profile
                    configurations.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="ManuallySorted" type="xs:boolean" use="optional" default="false">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether attributes in this group are manually sorted.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Deleted" use="optional" default="false" type="xs:boolean"/>
    </xs:complexType>
    <xs:complexType name="AttributeGroupLinkType">
        <xs:annotation>
            <xs:documentation>
                A link from an attribute to an attribute group.
            </xs:documentation>
        </xs:annotation>
        <xs:attribute name="AttributeGroupID" type="StepAttributeID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the attribute group.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="AttributeGroupListType">
        <xs:annotation>
            <xs:documentation>
                Container element for attribute groups.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="AttributeGroup" type="AttributeGroupType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="AttributeLinkType">
        <xs:annotation>
            <xs:documentation>
                A link to an attribute. Notice that only links from products and classifications can have metadata and
                that only some type can be dimension dependent.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="MetaData" type="MetaDataType" minOccurs="0"/>
            <xs:element name="ValueFilter" type="ValueFilterType" minOccurs="0"/>
        </xs:sequence>
        <xs:attribute name="Changed" use="optional" default="false" type="xs:boolean">
        </xs:attribute>
        <xs:attribute name="Inherited" type="xs:integer" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Only relevant during export when nested inside a product or classification. If present during import,
                    the link is simply ignored. If this attribute is present then link is inherited. Will not
                    be exported for local links (thus only numbers 1 and upward will be exported - 1 indicating
                    inherited from immediate parent).
                    The integer value of this attribute indicates how far up this link is inherited from.
                    In cross context exports it might be relevant to have this number to find the most relevant link
                    for a given context.
                    NOTE: will only inherit inside hierarchy of same equal node types - ie. will not inherit from
                    classification to product hierarchy.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="QualifierID" type="StepQualifierID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Identifies which contexts this link is visible in. If not specified the current context is used.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Mandatory" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Specifies whether or not this attribute is mandatory for products or assets
                    below this object. Must have on of the following values: true or false.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="AttributeID" type="StepAttributeID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the attribute.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
    </xs:complexType>
    <xs:complexType name="AttributeValidationType">
        <xs:annotation>
            <xs:documentation>
                The AttributeValidationType is used for describing a validity relation to an attribute.
            </xs:documentation>
        </xs:annotation>
        <xs:attribute name="AttributeID" type="StepAttributeID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the attribute.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="AttributeListType">
        <xs:annotation>
            <xs:documentation>
                Container element for attributes.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Attribute" type="AttributeType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="AttributeTransformationType">
        <xs:annotation>
            <xs:documentation>
                An attribute transformation is an object where a transformation of an attribute value can be specified.
                The transformation can then be linked to attributes. Transformations can be used in tables or the output
                system (currently only indesign).
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="UserTypeLink" type="UserTypeLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="AttributeGroupLink" type="AttributeGroupLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="AttributeLink" type="AttributeLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="Configuration" type="ConfigurationType" minOccurs="0"/>
        </xs:sequence>
        <xs:attribute name="ID" type="StepAttributeID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the attribute transformation.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ParentID" type="StepID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    ID of the parent group. When creating new group during import either ParentID or parent node is
                    required.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
    </xs:complexType>
    <xs:complexType name="AttributeTransformationGroupType">
        <xs:annotation>
            <xs:documentation>
                A grouping of several attribute transformations and / or other attribute transformation groups.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="AttributeTransformationGroup" type="AttributeTransformationGroupType" minOccurs="0"
                        maxOccurs="unbounded"/>
            <xs:element name="AttributeTransformation" type="AttributeTransformationType" minOccurs="0"
                        maxOccurs="unbounded"/>
        </xs:sequence>
        <xs:attribute name="ID" type="StepAttributeID" use="required"/>
        <xs:attribute name="ParentID" type="StepID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    ID of the parent group. When creating new group during import either ParentID or parent node is
                    required.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
    </xs:complexType>
    <xs:complexType name="AttributeTransformationGroupsType">
        <xs:annotation>
            <xs:documentation>
                A list of attribute transformation groups.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="AttributeTransformationGroup" type="AttributeTransformationGroupType" minOccurs="0"
                        maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="AutoPageAssetLinkType">
        <xs:choice minOccurs="0">
            <xs:element name="KeyValue" type="KeyValueType"/>
        </xs:choice>
        <xs:attribute name="AssetID" type="StepAssetID" use="required"/>
    </xs:complexType>
    <xs:complexType name="AutoPageClassificationLinkType">
        <xs:choice minOccurs="0">
            <xs:element name="KeyValue" type="KeyValueType"/>
        </xs:choice>
        <xs:attribute name="ClassificationID" type="StepClassificationID" use="required"/>
    </xs:complexType>
    <xs:complexType name="AutoPageProductLinkType">
        <xs:choice minOccurs="0">
            <xs:element name="KeyValue" type="KeyValueType"/>
        </xs:choice>
        <xs:attribute name="ProductID" type="StepProductID" use="required"/>
    </xs:complexType>
    <xs:complexType name="BasketType">
        <xs:choice minOccurs="0" maxOccurs="unbounded">
            <xs:element name="ClassificationBasketLink" type="ClassificationBasketLinkType"/>
            <xs:element name="ProductBasketLink" type="ProductBasketLinkType"/>
            <xs:element name="AssetBasketLink" type="AssetBasketLinkType"/>
        </xs:choice>
    </xs:complexType>
    <xs:complexType name="BulkUpdateConfigurationType">
        <xs:annotation>
            <xs:documentation>
                A bulk update configuration.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="MetaData" type="MetaDataType" minOccurs="0"/>
            <xs:element name="ClassificationReference" type="ClassificationReferenceType" minOccurs="0"
                        maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>
                        The classification(s) that the configuration is present in.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Configuration" type="ConfigurationType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>
                        The configuration in encoded form.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="ID" type="StepID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    Global identification of the object. Not required for creation if auto IDs are configured for the
                    object type.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="BulkUpdateConfigurationsType">
        <xs:annotation>
            <xs:documentation>
                Container element for bulk update configurations.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="BulkUpdateConfiguration" type="BulkUpdateConfigurationType" minOccurs="0"
                        maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="BusinessFunctionDependencyType">
        <xs:annotation>
            <xs:documentation>
                Represents a dependency to a business function.
            </xs:documentation>
        </xs:annotation>
        <xs:attribute name="FunctionID" type="StepBusinessRuleID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the business function.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="BusinessLibrariesType">
        <xs:annotation>
            <xs:documentation>
                Container element for business libraries.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="BusinessRule" type="BusinessRuleType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="BusinessRuleDependencyType">
        <xs:annotation>
            <xs:documentation>
                Represents a dependency to a business library.
            </xs:documentation>
        </xs:annotation>
        <xs:attribute name="LibraryID" type="StepBusinessRuleID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the business library.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="LibraryAlias" type="xs:string" use="required">
            <xs:annotation>
                <xs:documentation>
                    The alias name of the library when used in this context.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="BusinessRuleDescriptionType" mixed="true">
        <xs:annotation>
            <xs:documentation>
                A description of a business rule.
            </xs:documentation>
        </xs:annotation>
    </xs:complexType>
    <xs:complexType name="BusinessRuleLinkType">
        <xs:annotation>
            <xs:documentation>
                A link to a business rule.
            </xs:documentation>
        </xs:annotation>
        <xs:attribute name="ID" type="StepBusinessRuleID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the business rule.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="BusinessRulesType">
        <xs:annotation>
            <xs:documentation>
                Container element for non-library business rules.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="BusinessRule" type="BusinessRuleType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="BusinessRuleType">
        <xs:annotation>
            <xs:documentation>
                A business rule in STEP. Can represent an action, a condition, a function or a library.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="SetupGroupLink" type="SetupGroupLinkType" minOccurs="0"/>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="Description" type="BusinessRuleDescriptionType" minOccurs="0" maxOccurs="1"/>
            <xs:element name="Dependency" type="BusinessRuleDependencyType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="FunctionDependency" type="BusinessFunctionDependencyType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="OnApprove" type="OnApproveType" minOccurs="0" maxOccurs="1">
                <xs:annotation>
                    <xs:documentation>
                        Ignored for business rules of type library.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Configuration" type="ConfigurationType" minOccurs="0" maxOccurs="1">
                <xs:annotation>
                    <xs:documentation>
                        The configuration in encoded form.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ValidObjectTypes" type="ValidObjectTypesType" minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
        <xs:attribute name="ID" type="StepBusinessRuleID" use="required">
            <xs:annotation>
                <xs:documentation>
                    The ID of the business rule.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Scope" use="optional">
            <xs:annotation>
                <xs:documentation>
                    The scope of the business rule. Always "Global". Only applies for actions and conditions.
                </xs:documentation>
            </xs:annotation>
            <xs:simpleType>
                <xs:restriction base="xs:NMTOKEN">
                    <xs:enumeration value="Local"/>
                    <xs:enumeration value="Global"/>
                </xs:restriction>
            </xs:simpleType>
        </xs:attribute>
        <xs:attribute name="RunPrivileged" use="optional" default="false" type="xs:boolean">
            <xs:annotation>
                <xs:documentation>
                    Run privileged - without privilege check. Ignored for business rules of type library.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Type" use="required">
            <xs:annotation>
                <xs:documentation>
                    The type of the Business Rule.
                </xs:documentation>
            </xs:annotation>
            <xs:simpleType>
                <xs:restriction base="xs:NMTOKEN">
                    <xs:enumeration value="Condition"/>
                    <xs:enumeration value="Action"/>
                    <xs:enumeration value="Library"/>
                    <xs:enumeration value="Function"/>
                </xs:restriction>
            </xs:simpleType>
        </xs:attribute>
        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
    </xs:complexType>
    <xs:complexType name="CalculatedAttributeSettingsType">
        <xs:annotation>
            <xs:documentation>
                Describes dimension dependencies of all templates of calculated attributes in the STEP system.
                It goes for both value and unit templates of calculated attributes.
                On import it will not remove dimension dependencies.
                On import it will only add dimension dependencies as long as all existing dimension dependencies also
                are given in import file.
                In other words, all dimension dependencies needs to be provided on import.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="DimensionLink" type="DimensionLinkType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="CellType">
        <xs:annotation>
            <xs:documentation>
                Element that holds table cell definition. Notice: Because of backward compatibility, we do unfortunately
                not follow the normal first character uppercase convention for attributeID.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="ProductOrigin" type="ProductOriginType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="ClassificationOrigin" type="ClassificationOriginType" minOccurs="0"
                        maxOccurs="unbounded"/>
            <xs:element name="EntityOrigin" type="EntityOriginType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="AssetOrigin" type="AssetOriginType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="AttributeOrigin" type="AttributeOriginType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="Text" type="TextType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
        <xs:attribute name="ProcessFlag" type="xs:string" use="optional"/>
        <xs:attribute name="VerticalSpan" type="xs:string" use="optional"/>
        <xs:attribute name="HorizontalSpan" type="xs:string" use="optional"/>
        <xs:attribute name="Column" type="xs:string" use="optional"/>
        <xs:attribute name="RuleAbove" type="xs:string" use="optional"/>
        <xs:attribute name="BackgroundColor" type="xs:string" use="optional"/>
        <xs:attribute name="RuleBelow" type="xs:string" use="optional"/>
        <xs:attribute name="RuleRight" type="xs:string" use="optional"/>
        <xs:attribute name="CellRotation" type="xs:string" use="optional"/>
        <xs:attribute name="RuleLeft" type="xs:string" use="optional"/>
        <xs:attribute name="TextStyle" type="xs:string" use="optional"/>
        <xs:attribute name="VerticalAlignment" type="xs:string" use="optional"/>
        <xs:attribute name="CellVerticalStoryDirection" type="xs:string" use="optional"/>
        <xs:attribute name="CellImageScale" type="xs:string" use="optional"/>
        <xs:attribute name="attributeID" type="StepAttributeID" use="optional"/>
    </xs:complexType>
    <xs:complexType name="ChangePackagesType">
        <xs:sequence>
            <xs:element name="ChangePackage" type="ChangePackageType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="ChangePackageType">
        <xs:annotation>
            <xs:documentation>
                A change package.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="SetupGroupLink" type="SetupGroupLinkType" maxOccurs="1"  minOccurs="0">
                <xs:annotation>
                    <xs:documentation>
                        The setup group the package is located in.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="MetaData" type="MetaDataType" minOccurs="0"/>
            <xs:element name="Configuration" type="ConfigurationType" minOccurs="1" maxOccurs="1"/>
        </xs:sequence>
        <xs:attribute name="ID" type="StepID" use="required"/>
        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
    </xs:complexType>
    <xs:complexType name="CharacterTagGroupType">
        <xs:annotation>
            <xs:documentation>
                A tag group holding a number of tags and tag groups.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Name" type="NameType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="MetaData" type="MetaDataType" minOccurs="0"/>
            <xs:element name="AttributeGroupLink" type="AttributeGroupLinkType" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="CharacterTagGroup" type="CharacterTagGroupType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
        <xs:attribute name="ID" type="StepID" use="required">
            <xs:annotation>
                <xs:documentation>
                    Global identification of the object.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ParentID" type="StepID" use="optional">
            <xs:annotation>
                <xs:documentation>
                    ID of the parent tag group. When creating new group during import either ParentID or parent node is
                    required.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="Selected" type="xs:boolean" use="optional" default="true"/>
        <xs:attribute name="Referenced" type="xs:boolean" use="optional" default="false"/>
        <xs:attribute name="Changed" type="xs:boolean" use="optional" default="false"/>
    </xs:complexType>
    <xs:complexType name="CharacterTagType">
        <xs:annotation>
            <xs:documentation>
                Represents a character tag.
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Configuration" type="ConfigurationType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>
                        How tag content should be styled in STEP GUI.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Formatting" type="FormattingType" minOccurs="0" maxOccurs="unbounded"/>
